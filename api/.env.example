# ========== 로그인 DB 선택 ==========
# Oracle 사용 시: 아래 USE_LOCAL_DB 주석 처리(또는 제거)
# 로컬 SQLite만 쓸 때: USE_LOCAL_DB=1 로 설정
# USE_LOCAL_DB=1

# ========== Oracle DB (로그인 아이디/비밀번호 검증용) ==========
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_CONNECT_STRING=localhost:1521/ORCL

# 테이블/컬럼명이 다르면 지정 (기본: USERS, USER_ID, PASSWORD)
# DB_TABLE=USERS
# DB_USER_ID_COL=USER_ID
# DB_PASSWORD_COL=PASSWORD

# ========== Oracle Instant Client (Windows 64bit 필수) ==========
# https://www.oracle.com/database/technologies/instant-client/winx64-64-downloads.html
# 압축 해제 후 oci.dll 있는 폴더 경로 (start-dev.bat 에서 PATH 설정해도 됨)
# ORACLE_CLIENT_LIB_DIR=C:\oracle\instantclient_21_20

# 연결 테스트: 브라우저에서 http://localhost:3000/api/auth/db-check
